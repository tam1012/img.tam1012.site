# Auth/session
SESSION_SECRET=a_random_string_at_least_32_chars_long_change_this

# PostgreSQL
POSTGRES_PASSWORD=change-me-use-a-strong-password
DATABASE_URL=postgresql://imgstudio:change-me-use-a-strong-password@localhost:5432/imgstudio?schema=public

# Paid v1
IMAGE_PRICE_VND=100
VIDEO_PRICE_VND=5000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-at-least-8-chars

# PayOS (nạp tiền tự động) - lấy từ dashboard my.payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Base URL để dựng returnUrl/cancelUrl
# APP_BASE_URL=https://your-domain.example

# Data directory (default: ./data)
# DATA_DIR=/data

# API keys cho AI providers được cấu hình trên giao diện web (Cài đặt > AI Providers)
# Không cần set ở đây nữa

# xAI Video (tạo video bằng Grok) — lấy key từ console.x.ai
# XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai/v1

# ChatGPT Web Bridge (optional, host service)
# CHATGPT_BRIDGE_BASE_URL=http://host.docker.internal:8456

# Admin prompt refine (optional, OpenAI-compatible CPA)
# PROMPT_REFINE_BASE_URL=https://your-cpa.example/v1
# PROMPT_REFINE_API_KEY=change-me
# PROMPT_REFINE_MODEL=gemini-3-flash-agent
# PROMPT_REFINE_TIMEOUT_MS=25000

# Thư mục OAuth pool xAI do CPA quản lý, mount read-only trong Docker Compose
# XAI_AUTH_DIR=/run/secrets/xai-auths
# Host sync service dùng XAI_AUTH_SOURCE_DIR và XAI_AUTH_TARGET_DIR; app không cần hai biến này.

# Google Flow bridge (default disabled — fail closed)
# Ảnh: set FLOW_IMAGE_ROUTE=direct + FLOW_BRIDGE_* để bật Nano Banana 2/Pro qua bridge nội bộ.
FLOW_IMAGE_ROUTE=disabled
FLOW_VIDEO_ROUTE=disabled
FLOW_MODELS_PUBLIC=false
FLOW_CPA_IMAGE_BASE_URL=
FLOW_CPA_IMAGE_API_KEY=
FLOW_CPA_VIDEO_BASE_URL=http://flow-cpa-sidecar:8317/v1
FLOW_CPA_VIDEO_API_KEY=
FLOW_BRIDGE_BASE_URL=http://google-media-bridge:8460/v1
FLOW_BRIDGE_API_KEY=
FLOW_BRIDGE_ADMIN_BASE_URL=http://google-media-bridge:8460
FLOW_BRIDGE_ADMIN_KEY=
